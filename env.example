# ─── Cravez Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values before running the server.
# NEVER commit your actual .env file to version control.

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (Vercel → Settings → Environment Variables)
# Format: mongodb+srv://<user>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/cravez?retryWrites=true&w=majority

# Long random string for signing JWT tokens — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# Server port (defaults to 3000 locally; ignored by Vercel)
PORT=3000

# CORS origin — set to your frontend URL in production (e.g. https://cravez.vercel.app)
# Use * only during local development
CLIENT_ORIGIN=*

# Node environment — Vercel sets this to "production" automatically
NODE_ENV=development
