# ─── Cravez Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values before running the server.
# Never commit your actual .env file to version control.

# REQUIRED in production — a long random string for signing JWT tokens
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# Path to the SQLite database file (defaults to ./cravez.db if not set)
DB_PATH=./cravez.db

# Server port (defaults to 3000 if not set)
PORT=3000

# CORS origin — set to your frontend URL in production (e.g. https://app.cravez.com)
# Use * only during local development
CLIENT_ORIGIN=*

# Node environment — set to "production" on your server
NODE_ENV=development
